# API Gateway Configuration
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Redis Configuration (for job queue)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OTP / Phone Verification
# type for verify-otp can be 'sms' for phone or 'magiclink'/'otp' for email

# Python Workers Configuration
PYTHON_WORKERS_HOST=python-workers
PYTHON_WORKERS_PORT=5000
PYTHON_WORKERS_URL=http://python-workers:5000

# JWT Configuration
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=7d

# Logging
LOG_LEVEL=debug

# Google Sheets write access
# Share the target Google Sheet with this service account email as Editor.
# Recommended local dev option: point to the downloaded service account JSON file.
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=C:\Users\your-name\Downloads\abk-sheet-writer.json

# Alternative option: paste credentials directly.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
CONSTRUCTION_SHEET_NAME=Bài Viết Website - 2023
